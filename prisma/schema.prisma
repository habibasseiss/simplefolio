// Simplefolio — Wealth Management Schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(cuid())
  name      String    @default("Default User")
  accounts  Account[]
  createdAt DateTime  @default(now())
}

model Account {
  id           String        @id @default(cuid())
  name         String
  currency     String // ISO 4217, e.g. "USD", "EUR", "CAD"
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Transaction {
  id        String   @id @default(cuid())
  type      String // "BUY" | "SELL" | "DIVIDEND"
  symbol    String
  date      DateTime
  quantity  Float
  unitPrice Float
  fee       Float    @default(0)
  nraTax    Float? // Non-Resident Alien withholding tax rate (e.g. 0.3 = 30%)
  notes     String?
  accountId String
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Weekly adjusted-close prices fetched from Yahoo Finance.
// One row per (symbol, week). Synced incrementally — only missing weeks are fetched.
model PriceHistory {
  id       String   @id @default(cuid())
  symbol   String
  date     DateTime // Monday midnight UTC (week start)
  close    Float    // Split-adjusted close (adjclose from Yahoo)
  currency String

  @@unique([symbol, date])
  @@index([symbol])
}

// Cached instrument metadata from Yahoo Finance.
// Populated whenever a user selects a symbol via the search combobox.
model Symbol {
  ticker   String  @id
  name     String?
  exchange String?
}
