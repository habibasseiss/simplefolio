// Simplefolio — Wealth Management Schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(cuid())
  name      String    @default("Default User")
  accounts  Account[]
  createdAt DateTime  @default(now())
}

model Account {
  id           String        @id @default(cuid())
  name         String
  currency     String // ISO 4217, e.g. "USD", "EUR", "CAD"
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Transaction {
  id                 String   @id @default(cuid())
  type               String // "BUY" | "SELL" | "DIVIDEND"
  symbol             String
  instrumentType     String   @default("EQUITY") // "EQUITY" | "BOND"
  instrumentProvider String   @default("YAHOO") // "YAHOO" | "TESOURO"
  date               DateTime
  quantity           Float
  unitPrice          Float
  fee                Float    @default(0)
  purchaseRate       Float? // Contracted yield rate at purchase time (bonds only, e.g. 6.12 for IPCA+6.12%)
  nraTax             Float? // Non-Resident Alien withholding tax rate (e.g. 0.3 = 30%)
  notes              String?
  reinvestDividends  Boolean  @default(false) // DRIP: auto-reinvest dividends from this position
  isDrip             Boolean  @default(false) // true when this BUY was auto-created by DRIP
  accountId          String
  account            Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// Weekly adjusted-close prices fetched from a data provider.
// One row per (symbol, instrumentProvider, week). Synced incrementally — only missing weeks are fetched.
model PriceHistory {
  id                 String   @id @default(cuid())
  symbol             String
  instrumentProvider String   @default("YAHOO")
  date               DateTime // Monday midnight UTC (week start)
  close              Float // Split-adjusted close price
  currency           String

  @@unique([symbol, instrumentProvider, date])
  @@index([symbol, instrumentProvider])
}

// Cached instrument metadata.
// Populated whenever a user selects a symbol via the search combobox or adds a bond transaction.
model Symbol {
  ticker             String  @id
  name               String?
  exchange           String?
  instrumentType     String  @default("EQUITY") // "EQUITY" | "BOND"
  instrumentProvider String  @default("YAHOO") // "YAHOO" | "TESOURO"
}
