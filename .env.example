# PostgreSQL connection string
# Run `docker compose up db -d` first, then copy this file to .env
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/simplefolio

# For non US residents, the tax rate applied to dividends
NRA_TAX=0.30

# Secret used to protect cron endpoints (generate a random string and use it here)
CRON_SECRET=your_cron_secret_here

# Comma-separated list of currencies to fetch exchange rates for (e.g. USD,BRL)
CURRENCIES=USD,BRL

# URL of the Tesouro Direto API (used for fetching bond prices)
TESOURO_DIRETO_API_URL=http://localhost:3006
